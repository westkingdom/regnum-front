# Local development environment variables
# Copy this file to .env.local and fill in real values
# .env.local is gitignored and must never be committed

REGNUM_API_URL=https://regnum-api-85382560394.us-west1.run.app
BASE_URL=http://localhost:8501
STREAMLIT_ENV=development
BYPASS_GROUP_CHECK=true
LOCAL_SA_KEY_PATH=regnum-service-account-key.json

# Generate a new secret: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# Dev user database JSON — generate bcrypt hashes for each user:
# python3 -c "import bcrypt,getpass; p=getpass.getpass(); print(bcrypt.hashpw(p.encode(),bcrypt.gensalt()).decode())"
USERS_DB_JSON={"your@email.org":{"password_hash":"$2b$12$REPLACE","name":"Your Name","role":"admin"}}

# reCAPTCHA — leave as-is to disable in development, or set real keys to test
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
