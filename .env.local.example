# Local development environment variables
# Copy this file to .env.local and fill in real values
# .env.local is gitignored and must never be committed

REGNUM_API_URL=https://regnum-api-85382560394.us-west1.run.app
BASE_URL=http://localhost:8501
STREAMLIT_ENV=development

# Set true to skip Google Group membership check locally (do NOT set in production)
BYPASS_GROUP_CHECK=true

LOCAL_SA_KEY_PATH=regnum-service-account-key.json

# Used for signing OAuth state tokens (CSRF protection)
# Generate: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# Google OAuth 2.0 Web Application credentials
# Create in GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add http://localhost:8501/login as an authorized redirect URI
GOOGLE_CLIENT_ID=REPLACE_WITH_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_OAUTH_CLIENT_SECRET

# Google Workspace admin email for domain-wide delegation (group membership checks)
# Must be an actual admin account in westkingdom.org, not a mail alias
IMPERSONATED_USER_EMAIL=admin@westkingdom.org

# reCAPTCHA — leave as-is to disable in development, or set real keys to test
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
